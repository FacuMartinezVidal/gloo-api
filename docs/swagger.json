        "models.Recipe": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string",
                    "example": "Chicken"
                },
                "created_by": {
                    "type": "string",
                    "example": "@facu.potti"
                },
                "description": {
                    "type": "string",
                    "example": "A feast for the senses"
                },
                "estimated_time": {
                    "type": "string",
                    "example": "15 minutes"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "image_url": {
                    "type": "string",
                    "example": "https://example.com/image.png"
                },
                "title": {
                    "type": "string",
                    "example": "Chicken Wings"
                },
                "total_comments": {
                    "type": "integer",
                    "example": 10
                },
                "total_likes": {
                    "type": "integer",
                    "example": 20
                },
                "total_stars": {
                    "type": "number",
                    "example": 4.5
                }
            }
        },
        "routes.GetAllRecipeResponseData": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string",
                    "example": "Chicken"
                },
                "recipes": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Recipe"
                    }
                },
                "searchParam": {
                    "type": "string",
                    "example": "chicken"
                }
            }
        }
